{
  "name": "react-native-charts-wrapper",
  "repository": {
    "type": "git",
    "url": "https://github.com/wuxudong/react-native-charts-wrapper.git"
  },
  "version": "2.5.66",
  "description": "A react-native charts support both android and iOS.",
  "author": "wuxudong",
  "license": "MIT",
  "nativePackage": true,
  "homepage": "https://github.com/wuxudong/react-native-charts-wrapper",
  "keywords": [
    "react native",
    "chart",
    "android",
    "MPAndroidChart",
    "ios",
    "Charts"
  ],
  "files": [
    "android/src",
    "android/build.gradle",
    "android/gradle.properties",
    "ios/**/*.h",
    "ios/**/*.m",
    "ios/**/*.mm",
    "ios/**/*.swift",
    "lib",
    "src",
    "index.js",
    "react-native-charts-wrapper.podspec",
    "ios/ReactNativeCharts/ReactNativeCharts.xcodeproj/project.pbxproj"
  ],
  "dependencies": {
    "deprecated-react-native-prop-types": "^2.3.0",
    "prop-types": "^15.8.1"
  },
  "peerDependencies": {
    "react": ">=16.0.0",
    "react-native": ">=0.74.0"
  },
  "codegenConfig": {
    "name": "RNChartsWrapperSpec",
    "type": "components",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.github.wuxudong.rncharts"
    },
    "ios": {
      "componentProvider": {
        "RNCombinedChart": "RNCombinedChartComponentView",
        "RNBarChart": "RNBarChartComponentView",
        "RNHorizontalBarChart": "RNHorizontalBarChartComponentView",
        "RNLineChart": "RNLineChartComponentView",
        "RNBubbleChart": "RNBubbleChartComponentView",
        "RNScatterChart": "RNScatterChartComponentView",
        "RNCandleStickChart": "RNCandleStickChartComponentView",
        "RNPieChart": "RNPieChartComponentView",
        "RNRadarChart": "RNRadarChartComponentView"
      }
    }
  }
}
